graph TD
    Root[MedAlpha Connect<br/>Patient Mobile App]

    %% ===========================================
    %% LAYER 1: ENTRY & AUTH (Before Login)
    %% ===========================================

    Root --> Entry[Entry & Auth]

    %% Splash
    Entry --> SPL001["SPL-001 | Splash"]
    SPL001 --> SPL001_SEC1["Brand Mark"]
    SPL001 --> SPL001_SEC2["Loading State"]

    %% Onboarding
    Entry --> Onboarding[Onboarding]
    Onboarding --> ONB001["ONB-001 | Welcome & Language"]
    Onboarding --> ONB002["ONB-002 | Notification Permission"]
    ONB001 --> ONB001_SEC1["Value Props"]
    ONB001 --> ONB001_SEC2["Language Toggle"]
    ONB001 --> ONB001_SEC3["Continue CTA"]
    ONB002 --> ONB002_SEC1["Permission Prompt"]

    %% Authentication
    Entry --> Auth[Authentication]
    Auth --> AUTH001["AUTH-001 | Login / Register"]
    Auth --> AUTH003["AUTH-003 | Forgot Password"]
    Auth --> AUTH004["AUTH-004 | SSO Handoff"]
    AUTH001 --> AUTH001_SEC1["Login Tab"]
    AUTH001 --> AUTH001_SEC2["Register Tab"]
    AUTH001 --> AUTH001_SEC3["Social Login Options"]
    AUTH003 --> AUTH003_SEC1["Reset Link Form"]
    AUTH004 --> AUTH004_SEC1["Partner Handoff"]

    %% Profile Completion (conditional)
    Entry --> PRF001["PRF-001 | Profile Completion<br/>(shown if incomplete)"]
    PRF001 --> PRF001_SEC1["Completion Checklist"]
    PRF001 --> PRF001_SEC2["Required Fields"]

    %% ===========================================
    %% LAYER 2: MAIN APP (Bottom Tabs)
    %% ===========================================

    Root --> MainApp[Main App<br/>Bottom Tab Navigation]

    %% -------------------------------------------
    %% TAB 1: HOME
    %% -------------------------------------------
    MainApp --> HomeTab["Tab: Home"]

    HomeTab --> HOME001["HOME-001 | Home"]
    HOME001 --> HOME001_SEC1["Greeting & Upcoming Preview"]
    HOME001 --> HOME001_SEC2["Quick Actions"]
    HOME001 --> HOME001_SEC3["CMS Content Cards"]

    HomeTab --> HOME002["HOME-002 | Content Detail"]
    HOME002 --> HOME002_SEC1["Content Body"]

    %% -------------------------------------------
    %% TAB 2: APPOINTMENTS (Merged Hub)
    %% -------------------------------------------
    MainApp --> ApptTab["Tab: Appointments"]

    ApptTab --> APT001["APT-001 | Appointments Hub"]
    APT001 --> APT001_SEC1["Upcoming List<br/>(In-Person + Video)"]
    APT001 --> APT001_SEC2["Book In-Person CTA"]
    APT001 --> APT001_SEC3["Book Video Call CTA"]

    %% In-Person Flow (Curaay)
    ApptTab --> APT002["APT-002 | Book Appointment<br/>(Curaay WebView)"]
    APT002 --> APT002_SEC1["Curaay Booking UI"]

    ApptTab --> APT003["APT-003 | Appointment Confirmation"]
    APT003 --> APT003_SEC1["Confirmation Summary"]
    APT003 --> APT003_SEC2["Add to Calendar"]

    %% Telemedicine Flow (Teleclinic)
    ApptTab --> APT004["APT-004 | Teleclinic Entry"]
    APT004 --> APT004_SEC1["Session Info"]
    APT004 --> APT004_SEC2["Launch Video CTA"]

    ApptTab --> APT005["APT-005 | Teleclinic Session<br/>(WebView)"]
    APT005 --> APT005_SEC1["Teleclinic Video UI"]

    %% Post-Appointment (Push Triggered)
    ApptTab --> APT006["APT-006 | Post-Appointment Follow-up<br/>(via push notification)"]
    APT006 --> APT006_SEC1["Satisfaction Check"]
    APT006 --> APT006_SEC2["Redeem Prescription Prompt"]

    %% -------------------------------------------
    %% TAB 3: PRESCRIPTIONS
    %% -------------------------------------------
    MainApp --> RxTab["Tab: Prescriptions"]

    RxTab --> RX001["RX-001 | Prescriptions Hub"]
    RX001 --> RX001_SEC1["Active Prescriptions"]
    RX001 --> RX001_SEC2["Orders In Progress"]
    RX001 --> RX001_SEC3["Redeem CTA"]

    RxTab --> RX002["RX-002 | Choose Delivery Method"]
    RX002 --> RX002_SEC1["Home Delivery Option"]
    RX002 --> RX002_SEC2["Pick Up at Pharmacy Option"]
    RX002 --> RX002_SEC3["Legal Notice"]

    %% Home Delivery Flow
    RxTab --> RX003["RX-003 | NFC Intro"]
    RX003 --> RX003_SEC1["What You Need"]
    RX003 --> RX003_SEC2["NFC Explanation"]

    RxTab --> RX003B["RX-003B | Consent<br/>(NEW - Trust Building)"]
    RX003B --> RX003B_SEC1["What We Read"]
    RX003B --> RX003B_SEC2["What We Don't Access"]
    RX003B --> RX003B_SEC3["Security Assurances"]
    RX003B --> RX003B_SEC4["Consent Checkbox"]

    RxTab --> RX004["RX-004 | NFC Scan"]
    RX004 --> RX004_SEC1["Scan Animation"]
    RX004 --> RX004_SEC2["Status Indicator"]
    RX004 --> RX004_SEC3["Cancel CTA"]

    RxTab --> RX005["RX-005 | Order Status"]
    RX005 --> RX005_SEC1["Order Timeline"]
    RX005 --> RX005_SEC2["Delivery Address"]
    RX005 --> RX005_SEC3["Support CTA"]

    %% Pick Up Flow
    RxTab --> RX006["RX-006 | Pharmacy Search"]
    RX006 --> RX006_SEC1["Map View"]
    RX006 --> RX006_SEC2["Results List"]

    RxTab --> RX007["RX-007 | Pharmacy Detail"]
    RX007 --> RX007_SEC1["Pharmacy Info"]
    RX007 --> RX007_SEC2["Opening Hours"]
    RX007 --> RX007_SEC3["Directions CTA"]

    %% -------------------------------------------
    %% TAB 4: HISTORY
    %% -------------------------------------------
    MainApp --> HistoryTab["Tab: History"]

    HistoryTab --> HIS001["HIS-001 | History<br/>(All tab default)"]
    HIS001 --> HIS001_TAB1["All Tab (default)"]
    HIS001 --> HIS001_TAB2["Appointments Tab"]
    HIS001 --> HIS001_TAB3["Prescriptions Tab"]
    HIS001 --> HIS001_TAB4["Telemedicine Tab"]

    HistoryTab --> HIS002["HIS-002 | Appointment Detail"]
    HIS002 --> HIS002_SEC1["Appointment Info"]
    HIS002 --> HIS002_SEC2["Visit Notes"]
    HIS002 --> HIS002_SEC3["Related Prescriptions"]
    HIS002 --> HIS002_SEC4["Book Follow-up CTA"]

    HistoryTab --> HIS003["HIS-003 | Prescription Detail"]
    HIS003 --> HIS003_SEC1["Prescription Info"]
    HIS003 --> HIS003_SEC2["Redemption Status"]
    HIS003 --> HIS003_SEC3["Related Appointment"]

    HistoryTab --> HIS004["HIS-004 | Telemedicine Detail"]
    HIS004 --> HIS004_SEC1["Consultation Info"]
    HIS004 --> HIS004_SEC2["Session Summary"]
    HIS004 --> HIS004_SEC3["Related Prescriptions"]

    %% ===========================================
    %% LAYER 3: SECONDARY (Menu Access)
    %% ===========================================

    Root --> Secondary[Secondary Screens<br/>Menu Access]

    %% Profile
    Secondary --> PRF002["PRF-002 | Profile"]
    PRF002 --> PRF002_SEC1["Profile Summary"]
    PRF002 --> PRF002_SEC2["Personal Info Section"]
    PRF002 --> PRF002_SEC3["Contact Section"]
    PRF002 --> PRF002_SEC4["Insurance Section"]

    Secondary --> PRF003["PRF-003 | Edit Profile"]
    PRF003 --> PRF003_SEC1["Edit Form"]

    %% Settings
    Secondary --> SET001["SET-001 | Settings"]
    SET001 --> SET001_SEC1["Preferences Section"]
    SET001 --> SET001_SEC2["Account Section"]
    SET001 --> SET001_SEC3["App Info"]

    Secondary --> SET002["SET-002 | Language & Region"]
    SET002 --> SET002_SEC1["Language Selection"]
    SET002 --> SET002_SEC2["Region Selection"]

    Secondary --> SET003["SET-003 | Notifications"]
    SET003 --> SET003_SEC1["Push Toggles"]

    Secondary --> SET004["SET-004 | Account Actions<br/>(NEW)"]
    SET004 --> SET004_SEC1["Change Password"]
    SET004 --> SET004_SEC2["Logout"]
    SET004 --> SET004_SEC3["Delete Account"]

    %% Static Pages
    Secondary --> STA001["STA-001 | FAQ"]
    STA001 --> STA001_SEC1["FAQ List"]

    Secondary --> STA002["STA-002 | Support"]
    STA002 --> STA002_SEC1["Contact Options"]

    Secondary --> STA003["STA-003 | Privacy Policy"]
    STA003 --> STA003_SEC1["Privacy Content"]

    Secondary --> STA004["STA-004 | Legal Disclosure"]
    STA004 --> STA004_SEC1["Legal Content"]

    %% ===========================================
    %% NAVIGATION MODEL
    %% ===========================================

    Root --> NavModel[Navigation Model]
    NavModel --> NavTabs["Bottom Tabs<br/>Home | Appointments | Prescriptions | History"]
    NavModel --> NavMenu["Top-Right Menu<br/>Profile | Settings | FAQ | Support | Privacy | Legal | Logout"]
    NavModel --> NavModals["Modal Flows<br/>Auth | NFC Scan | WebViews"]

    %% ===========================================
    %% STYLING
    %% ===========================================

    classDef layer fill:#e1f5fe,stroke:#01579b
    classDef tab fill:#fff3e0,stroke:#e65100
    classDef screen fill:#f3e5f5,stroke:#7b1fa2
    classDef section fill:#e8f5e9,stroke:#2e7d32
    classDef new fill:#ffebee,stroke:#c62828
    classDef nav fill:#fce4ec,stroke:#880e4f

    class Entry,MainApp,Secondary layer
    class HomeTab,ApptTab,RxTab,HistoryTab tab
    class SPL001,ONB001,ONB002,AUTH001,AUTH003,AUTH004,PRF001,PRF002,PRF003 screen
    class HOME001,HOME002,APT001,APT002,APT003,APT004,APT005,APT006 screen
    class RX001,RX002,RX003,RX004,RX005,RX006,RX007 screen
    class HIS001,HIS002,HIS003,HIS004 screen
    class SET001,SET002,SET003,STA001,STA002,STA003,STA004 screen
    class RX003B,SET004 new
    class NavModel,NavTabs,NavMenu,NavModals nav
